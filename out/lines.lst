     7 				; =====================================================================
     8 				; fightAttract
     9 				; Call this every frame in your stop loop to prevent attract mode
    10 				; from desaturating your colors
    11 				; ON ENTRY: nothing
    12 				; ON EXIT:  attract mode defeated for this frame
    13 				;======================================================================
    14 				        .proc fightAttract
    15
    16 				        ; defeat attract mode and set colors
    17 FFFF> 3000-3116> A9 00 +         mva #0    ATRACT
    18 3004 A9 FF 85 4E		        mva #$FF  ATRMSK
    19
    20 3008 60			        rts
    21 				        .endp
    22
    23 				; =====================================================================
    24 				; Clear the screen
    25
    26 3009			        .proc clearScreen
    27
    28 				; initialize pointer from SAVMSC
    29 3009 A5 58		        lda SAVMSC
    30 300B 85 85		        sta scrptr_lo
    31 300D A5 59		        lda SAVMSC+1
    32 300F 85 86		        sta scrptr_hi
    33
    34 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
    35 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
    36 				; because Y equals zero — exiting the inner loop into the outer loop.
    37
    38 3011 A2 1E		        ldx #30             ; X = 30 pages to clear
    39 3013 A0 00		        ldy #0              ; Y = byte index within page
    40
    41 3015			clearpage:
    42 3015 A9 00		        lda #$00
    43 3017 91 85		        sta (scrptr_lo),y   ; write $00
    44 3019 C8			        iny                 ; next byte
    45 301A D0 F9		        bne clearpage       ; inner loop — 256 bytes
    46
    47 301C E6 86		        inc scrptr_hi       ; advance to next page
    48 301E CA			        dex                 ; X = X - 1
    49 301F D0 F4		        bne clearpage       ; outer loop — 30 pages
    50
    51 3021 60			        rts
    52 				        .endp
    53
    54
    55 				; =====================================================================
    56 				; Open Graphics Mode 8
    57
    58 3022			        .proc openGR8
    59
    60 				; =====================================================================
    61 				; STEP 1: Close IOCB6
    62 				; Good practice to close before opening — ensures clean state.
    63 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
    64 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
    65 				; ON EXIT:  IOCB6 is closed and ready to be reopened
    66 				; =====================================================================
    67 3022 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    68 3024 A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
    69 3026 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
    70 3029 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
    71
    72 				; =====================================================================
    73 				; STEP 2: Open Graphics Mode 8
    74 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
    75 				; CIO sets up the display list, allocates screen RAM, configures
    76 				; ANTIC — everything needed for graphics mode automatically.
    77 				; ON ENTRY: nothing required
    78 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
    79 				; =====================================================================
    80 302C A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    81 302E A9 03		        lda #$03                    ; A = $03        (OPEN command)
    82 3030 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
    83 3033 A9 14		        lda #<scrname               ; A = low byte of "S:" string address
    84 3035 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
    85 3038 A9 31		        lda #>scrname               ; A = high byte of "S:" string address
    86 303A 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
    87 303D A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
    88 303F 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
    89 3042 A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
    90 3044 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
    91 3047 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
    92
    93 				; Step 3: Setup color registers
    94 				; change COLPF1 to change pixel color
    95
    96 304A A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
    97 304F A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
    98 3054 A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
    99
   100 3059 60			        rts
   101 				        .endp
