    53 				; =====================================================================
    54 				; CIO (Central I/O) constants
    55 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    56 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    57 				; of memory containing command, device, buffer address, and aux bytes.
    58 				; We use IOCB6 (base address $0360) for graphics.
    59 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    60 				; =====================================================================
    61 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    62 = 0342			ICCOM   = $0342     ; IOCB6 command register
    63 				                    ;   $03 = OPEN   (open a device)
    64 				                    ;   $0C = CLOSE  (close a device)
    65 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    66 				                    ;   for OPEN: points to device name string "S:"
    67 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    68 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    69 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    70 				                    ;   for OPEN: $0C = read/write access mode
    71 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    72 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    73
    74 				; =====================================================================
    75 				; Screen RAM pointer
    76 				; After CIO opens GR.8, the OS stores the address of screen RAM
    77 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    78 				; On our 800XL PAL system screen RAM ends up at $B060.
    79 				; =====================================================================
    80 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    81 				                    ; $59 automatically contains the high byte
    82
    83 				; =====================================================================
    84 				; Attract mode constants
    85 				; The Atari OS has an attract mode that kicks in after inactivity
    86 				; to prevent screen burn-in. It does this by desaturating all colors
    87 				; making everything appear as shades of grey/blue.
    88 				; We must continuously reset these in our main loop to keep colors!
    89 				; =====================================================================
    90 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    91 				                    ; when it reaches a threshold attract mode activates
    92 				                    ; we keep writing 0 to prevent it from activating
    93 = 004E			ATRMSK  = $4E       ; attract mode color mask
    94 				                    ; OS ANDs all colors with this value
    95 				                    ; $FE strips hue leaving only luminance (grey/blue)
    96 				                    ; $FF = full color (no masking) — what we want
     2 				        icl 'routines.asm'
