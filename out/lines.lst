   232 				;=========================================================================================
   233 				; print a string
   234 				; Assumptions
   235 				; strptr_lo = low address of the string
   236 				; strptr_hi = high address of the string
   237 				;       together we have a 16-bit address of the string
   238
   239 				; Y = index of current character to process, starts at 0
   240 				; example calling code:
   241 				;       mva #1 csrhinh                  ; hide the cursor
   242 				;        mva #6 rowcrs                   ; set output row
   243 				;        mva #10 colcrs                  ; set output column
   244 				;        
   245 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   246 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   247 				;        jsr print_string                ; print the string
   248 				;
   249 				;========= don't forget you'll need data
   250 				;       .local string1
   251 				;        .byte 'HELLO FROM STRING ONE!',0
   252 				;        .endl
   253
   254 				;======================================================================
   255 30DB			        .proc print_string
   256 30DB A0 00		        ldy #0
   257 30DD			loop:
   258 30DD B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   259 30DF C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   260 30E1 F0 0D		        beq exit                        ; if true, branch to exit
   261 30E3 98			        tya                             ; A = Y
   262 30E4 48			        pha                             ; push A onto the stack
   263 30E5 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   264 30E7 20 F4 30		        jsr putchar                     ; call putchar to write a character out
   265 30EA 68			        pla                             ; A = pop stack
   266 30EB A8			        tay                             ; Y = A
   267 30EC C8			        iny                             ; Y = Y + 1
   268 30ED 4C DD 30		        jmp loop                        ; GOTO loop
   269 30F0			exit:
   270 30F0 60			        rts                             ; exit subroutine
   271 				        .endp
   272
   273 30F1			stop:
   274 30F1 4C F1 30		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   275 				;======================================================================
   276
   277 				; print a character
   278 				; Assumptions
   279 				; 1. the character is in register A
   280 				; 2. the character has been converted to ATASCII
   281 				; 3. before calling, save values of X and Y registers
   282
   283 30F4			        .proc putchar
   284 30F4 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   285 30F5 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   286 30F8 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   287 30F9 AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   288 30FC 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   289 30FD 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   290 30FE 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   291 				        .endp           ; end of putchar procedure
   292
   293 				;========================================================================================
   294 				        ; print both digits in base 10, from left to right
   295 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   296 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   297 				        ; Assumtions: A contains the hex value of the number to print
   298
   299 30FF			        .proc printDecimal
   300 30FF A2 00		        ldx #0
   301 3101			checkCount:
   302 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   303 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   304 3101 C9 0A		        cmp #10             ; Does A = 10?
   305 3103 90 07		        bcc doneCounting    ; branch if carry is cleared
   306 3105 38			        sec                 ; set carry
   307 3106 E9 0A		        sbc #10             ; A = A - 10
   308 3108 E8			        inx                 ; X = X + 1
   309 3109 4C 01 31		        jmp checkCount
   310
   311 310C			doneCounting:   
   312 310C 48			        pha                 ; push(A) (push A onto the stack)
   313 310D 8A			        txa                 ; A = X
   314 310E 18			        clc
   315 310F 69 30		        adc #offset_to_char
   316 3111 20 F4 30		        jsr putchar
   317
   318 3114 68			        pla                 ; A = pop() (pop the next value off the stack)
   319 3115 18			        clc 
   320 3116 69 30		        adc #offset_to_char
   321 3118 20 F4 30		        jsr putchar
   322 				        .endp
   323 				;==================================================================================================
   324
   325 				; plot a point (x,y)
   326 				; Step 1: Find which ROW we're on
   327 				;        plotY × 40 = how many bytes to skip to reach our row
   328 				;        (each row is 40 bytes wide)
   329 				;        2^3 + 2^2
   330 				; Step 2: Find which BYTE within that row
   331 				;        plotX ÷ 8 = which byte contains our pixel
   332 				;        (each byte holds 8 pixels)
   333 				;
   334 				; Step 3: Add them together
   335 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   336 				;
   337 				; Step 4: Add SAVMSC
   338 				;        SAVMSC + offset = actual address in memory of our byte
   339 				;
   340 				; Step 5: Find which BIT within that byte
   341 				;        7 - (plotX mod 8) = which bit is our pixel
   342 				;
   343 				; Step 6: Set that bit
   344 				;        read the byte
   345 				;        OR with our bit mask
   346 				;        write the byte back
   347 				;
   348 311B			        .proc plotPoint
   349
   350 				        ; see multiplyingYby40.txt for full breakdown with an example!
   351
   352 				        ; defeat attract mode on every plot
   353 311B A9 00 85 4D		        mva #0    ATRACT
   354 311F A9 FF 85 4E		        mva #$FF  ATRMSK
   355
   356 				        ; Step 1: Find which ROW we're on
   357 3123 A5 82		        lda plotY
   358 3125 85 83		        sta temp_lo         ; temp = plotY
   359 3127 A9 00		        lda #0
   360 3129 85 84		        sta temp_hi         ; high byte starts at 0
   361
   362 				        ; × 2
   363 312B 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   364 312D 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   365
   366 				        ; × 4
   367 312F 06 83		        asl temp_lo
   368 3131 26 84		        rol temp_hi
   369
   370 				        ; × 8  ← save this!
   371 3133 06 83		        asl temp_lo
   372 3135 26 84		        rol temp_hi
   373 3137 A5 83		        lda temp_lo
   374 3139 85 87		        sta save_lo
   375 313B A5 84		        lda temp_hi
   376 313D 85 88		        sta save_hi
   377
   378 				        ; × 16
   379 313F 06 83		        asl temp_lo
   380 3141 26 84		        rol temp_hi
   381
   382 				        ; × 32
   383 3143 06 83		        asl temp_lo
   384 3145 26 84		        rol temp_hi
   385
   386 3147 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   387 3149 18			        clc                 ; clear carry
   388 314A 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   389 314C 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   390
   391 314E A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   392 3150 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   393 3152 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   394 				        ; we now have the offset to our target row in temp_lo and temp_hi
   395
   396 				        ; calculate which bit 
   397 3154 A5 80		        lda plotX_lo
   398 3156 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   399 3158 85 89		        sta bitpos          ; save for Step 5
   400
   401 				        ; Step 2: find offset from start of row to our pixel
   402 				        ; plotX ÷ 8 using 16-bit right shift
   403 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   404 				        ; ON EXIT:  A contains column byte offset (0-39)
   405 315A 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   406 315C 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   407
   408 315E 46 81		        lsr plotX_hi        ; shift again
   409 3160 66 80		        ror plotX_lo
   410
   411 3162 46 81		        lsr plotX_hi        ; shift again
   412 3164 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   413
   414 				        ; Step 3: add results from step 1 and 2 together
   415 3166 A5 83		        lda temp_lo
   416 3168 18			        clc
   417 3169 65 80		        adc plotX_lo
   418 316B 85 83		        sta temp_lo
   419
   420 316D A5 84		        lda temp_hi
   421 316F 69 00		        adc #0
   422 3171 85 84		        sta temp_hi
   423 				        ; temp now contains total byte offset from SAVMSC
   424
   425 				        ; Step 4: Add SAVMSC Base Address
   426 3173 A5 83		        lda temp_lo
   427 3175 18			        clc
   428 3176 65 58		        adc SAVMSC
   429 3178 85 85		        sta scrptr_lo
   430
   431 317A A5 84		        lda temp_hi
   432 317C 65 59		        adc SAVMSC+1
   433 317E 85 86		        sta scrptr_hi
   434
   435 				        ; Step 5: find which bit to turn on
   436 				        ; algo:  bit position = 7 - (plotX mod 8)
   437 				        ; Step 5: find which bit to turn on
   438 3180 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   439 3182 A6 89		        ldx bitpos          ; X = number of times to shift right
   440 3184 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   441 3186			shift_loop:
   442 3186 4A			        lsr                 ; shift A right one position
   443 3187 CA			        dex                 ; X = X - 1
   444 3188 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   445 318A			done_shift:
   446 				                            ; A now contains our bit mask
   447
   448 				        ; Step 6: turn on our bit!!
   449 318A 85 8A		        sta bitmask             ; save mask
   450 318C A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   451 318E B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   452 3190 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   453 3192 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   454
   455 3194 60			        rts
   456 				        .endp
   457 				;======================================================================
   458
