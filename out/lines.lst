     7 				; =====================================================================
     8 				; fightAttract
     9 				; Call this every frame in your stop loop to prevent attract mode
    10 				; from desaturating your colors
    11 				; ON ENTRY: nothing
    12 				; ON EXIT:  attract mode defeated for this frame
    13 				;======================================================================
    14 				        .proc fightAttract
    15
    16 				        ; defeat attract mode and set colors
    17 FFFF> 3000-31D0> A9 00 +         mva #0    ATRACT
    18 3004 A9 FF 85 4E		        mva #$FF  ATRMSK
    19
    20 3008 60			        rts
    21 				        .endp
    22
    23 				; =====================================================================
    24 				; Clear the screen
    25
    26 3009			        .proc clearScreen
    27
    28 				; initialize pointer from SAVMSC
    29 3009 A5 58		        lda SAVMSC
    30 300B 85 85		        sta scrptr_lo
    31 300D A5 59		        lda SAVMSC+1
    32 300F 85 86		        sta scrptr_hi
    33
    34 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
    35 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
    36 				; because Y equals zero — exiting the inner loop into the outer loop.
    37
    38 3011 A2 1E		        ldx #30             ; X = 30 pages to clear
    39 3013 A0 00		        ldy #0              ; Y = byte index within page
    40
    41 3015			clearpage:
    42 3015 A9 00		        lda #$00
    43 3017 91 85		        sta (scrptr_lo),y   ; write $00
    44 3019 C8			        iny                 ; next byte
    45 301A D0 F9		        bne clearpage       ; inner loop — 256 bytes
    46
    47 301C E6 86		        inc scrptr_hi       ; advance to next page
    48 301E CA			        dex                 ; X = X - 1
    49 301F D0 F4		        bne clearpage       ; outer loop — 30 pages
    50
    51 3021 60			        rts
    52 				        .endp
    53
    54
    55 				; =====================================================================
    56 				; Open Graphics Mode 8
    57
    58 3022			        .proc openGR8
    59
    60 				; =====================================================================
    61 				; STEP 1: Close IOCB6
    62 				; Good practice to close before opening — ensures clean state.
    63 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
    64 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
    65 				; ON EXIT:  IOCB6 is closed and ready to be reopened
    66 				; =====================================================================
    67 3022 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    68 3024 A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
    69 3026 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
    70 3029 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
    71
    72 				; =====================================================================
    73 				; STEP 2: Open Graphics Mode 8
    74 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
    75 				; CIO sets up the display list, allocates screen RAM, configures
    76 				; ANTIC — everything needed for graphics mode automatically.
    77 				; ON ENTRY: nothing required
    78 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
    79 				; =====================================================================
    80
    81
    82 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 8
    83 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
    84 				;   pixel data directly to screen RAM.
    85 				;   GR.8:   320 pixels wide × 192 tall   1 bit per pixel     2 colors
    86 				;   GR.8:   40 bytes × 192 rows = 7,680 bytes
    87 				;   GR.8:   320 pixels ÷ 8 pixels per byte = 40 bytes per row
    88 				;   GR.8 byte:  P P P P P P P P
    89 				;               | | | | | | | |
    90 				;               7 6 5 4 3 2 1 0   (8 pixels, 1 bit each, on or off)
    91
    92 302C A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    93 302E A9 03		        lda #$03                    ; A = $03        (OPEN command)
    94 3030 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
    95 3033 A9 CE		        lda #<scrname               ; A = low byte of "S:" string address
    96 3035 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
    97 3038 A9 31		        lda #>scrname               ; A = high byte of "S:" string address
    98 303A 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
    99 303D A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
   100 303F 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
   101 3042 A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   102 3044 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   103 3047 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   104
   105 				; Step 3: Setup color registers
   106 				; change COLPF1 to change pixel color
   107
   108 304A A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
   109 304F A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
   110 3054 A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
   111
   112 3059 60			        rts
   113 				        .endp
   114
   115 				;=========================================================================================
   116 				; draw a line using Bresenham's algorithm
   117
   118 305A			        .proc drawLine
   119
   120 				        ; first step, compute:
   121 				        ; dx = x2 - x1    (16-bit subtraction)
   122 				        ; dy = y2 - y1    (8-bit subtraction)
   123
   124 305A A5 92		        lda y2          ; A = Y2
   125 305C 38			        sec             ; set carry
   126 305D E5 8F		        sbc y1          ; A = A - Y1
   127 305F 85 95		        sta dy          ; dy = A
   128
   129 3061 A5 90		        lda x2          ; A = x2 (low byte)
   130 3063 38			        sec             ; set carry
   131 3064 E5 8D		        sbc x1          ; A = A - X1 (low byte)
   132 3066 85 93		        sta dx_lo       ; save low byte, but do not re-set carry
   133
   134 3068 A5 91		        lda x2_hi       ; A = X2 (high byte)
   135 306A E5 8E		        sbc x1_hi       ; A = A - X1 (high byte)
   136 306C 85 94		        sta dx_hi       ; save high byte
   137
   138 				        ; check for vertical line (dx = 0)
   139 306E A5 93		        lda dx_lo
   140 3070 05 94		        ora dx_hi       ; OR low and high bytes together
   141 3072 D0 33		        bne not_vertical ; if result != 0, not vertical
   142
   143 				        ; handle vertical line
   144 				        ; initialize position first!
   145 3074 A5 8D		        lda x1
   146 3076 85 80		        sta plotX_lo
   147 3078 A5 8E		        lda x1_hi
   148 307A 85 81		        sta plotX_hi
   149 307C A5 8F		        lda y1
   150 307E 85 82		        sta plotY
   151
   152 				        ; just loop Y from y1 to y2
   153 3080			vertical_loop:
   154 3080 A5 80		        lda plotX_lo    ; save plotX before plotPoint destroys it
   155 3082 48			        pha
   156 3083 A5 81		        lda plotX_hi
   157 3085 48			        pha
   158 				        
   159 3086 20 54 31		        jsr plotPoint
   160 				        
   161 3089 68			        pla             ; restore plotX
   162 308A 85 81		        sta plotX_hi
   163 308C 68			        pla
   164 308D 85 80		        sta plotX_lo
   165 				        
   166 308F E6 82		        inc plotY
   167 3091 A5 82		        lda plotY
   168 3093 C5 92		        cmp y2
   169 3095 D0 E9		        bne vertical_loop
   170 				        
   171 				        ; plot final point
   172 3097 A5 80		        lda plotX_lo
   173 3099 48			        pha
   174 309A A5 81		        lda plotX_hi
   175 309C 48			        pha
   176 309D 20 54 31		        jsr plotPoint
   177 30A0 68			        pla
   178 30A1 85 81		        sta plotX_hi
   179 30A3 68			        pla
   180 30A4 85 80		        sta plotX_lo
   181 				        
   182 30A6 60			        rts
   183
   184 30A7			not_vertical:
   185 				        ; continue with normal Bresenham...
   186
   187 				        ; initialize current position to start point
   188 30A7 A5 8D		        lda x1          ; A = X1
   189 30A9 85 80		        sta plotX_lo    ; plotX_lo = A
   190 30AB A5 8E		        lda x1_hi       ; A = X1_hi
   191 30AD 85 81		        sta plotX_hi    ; plotX_hi = A
   192 30AF A5 8F		        lda y1          ; A = Y1
   193 30B1 85 82		        sta plotY       ; plotY = A
   194
   195 				        ; initialize error to 0
   196 30B3 A9 00 85 96		        mva #0 err_lo           ; err_lo = 0
   197 30B7 A9 00 85 97		        mva #0 err_hi           ; err_hi = 0
   198
   199 30BB			lineloop:
   200 				        ; save plotX before plotPoint destroys it
   201 30BB A5 80		        lda plotX_lo
   202 30BD 48			        pha
   203 30BE A5 81		        lda plotX_hi
   204 30C0 48			        pha
   205
   206 30C1 20 54 31		        jsr plotPoint
   207
   208 				        ; restore plotX after plotPoint
   209 30C4 68			        pla
   210 30C5 85 81		        sta plotX_hi
   211 30C7 68			        pla
   212 30C8 85 80		        sta plotX_lo
   213
   214 				; add dy to error accumulator (16-bit + 8-bit addition)
   215 30CA A5 96		        lda err_lo              ; A = err_lo
   216 30CC 18			        clc                     ; clear carry
   217 30CD 65 95		        adc dy                  ; A += dy
   218 30CF 85 96		        sta err_lo              ; err_lo = A
   219 30D1 A5 97		        lda err_hi              ; A = err_hi
   220 30D3 69 00		        adc #0                  ; propagate carry trick. if the carry was set it gets added to the high byte
   221 30D5 85 97		        sta err_hi              ; err_hi = A
   222
   223 				        ; check if error * 2 >= dx
   224 				        ; compute error + error (16-bit)
   225 30D7 A5 96		        lda err_lo              ; A = err_lo
   226 30D9 18			        clc                     ; clear carry
   227 30DA 65 96		        adc err_lo              ; A += err_lo (err_lo * 2)
   228 30DC 85 83		        sta temp_lo             ; temp_lo = A
   229 30DE A5 97		        lda err_hi              ; A = err_hi
   230 30E0 65 97		        adc err_hi              ; A += err_hi ((err_hi * 2) + carry)
   231 30E2 85 84		        sta temp_hi             ; temp_hi = A
   232
   233 				        ; compare temp (error*2) to dx
   234 				        ; 16-bit comparison: check high byte first, then low byte
   235 30E4 A5 84		        lda temp_hi     ; A = temp_hi
   236 30E6 C5 94		        cmp dx_hi       ; Does temp_hi == dx_hi? 
   237 30E8 90 17		        bcc skip_y      ; temp_hi < dx_hi, no Y step needed (branch if carry is clear)
   238 30EA D0 06		        bne do_y_step   ; temp_hi > dx_hi, Y step needed (branch if not equal)
   239 30EC A5 83		        lda temp_lo     ; A = temp_lo (high bytes equal, check low bytes (if we got here, high bytes are equal))
   240 30EE C5 93		        cmp dx_lo       ; Does temp_lo == dx_lo?
   241 30F0 90 0F		        bcc skip_y      ; temp_lo < dx_lo, no Y step needed
   242
   243 30F2			do_y_step:
   244 30F2 E6 82		        inc plotY       ; y = y + 1
   245
   246 				        ; error = error - dx (16-bit subtraction)
   247 30F4 A5 96		        lda err_lo      ; A = err_lo
   248 30F6 38			        sec             ; set the carry
   249 30F7 E5 93		        sbc dx_lo       ; A -= dx_lo
   250 30F9 85 96		        sta err_lo      ; err_lo = A
   251 30FB A5 97		        lda err_hi      ; A = err_hi
   252 30FD E5 94		        sbc dx_hi       ; A -= dex_hi
   253 30FF 85 97		        sta err_hi      ; err_hi = A
   254
   255 3101			skip_y:
   256 				        ; advance x (16-bit increment)
   257 3101 E6 80		        inc plotX_lo            ; plotX_lo++
   258 3103 D0 02		        bne lineloop_check      ; if no overflow, check if done 
   259 				                                ; if plotX_lo != 0 JUMP FORWARD to lineloop_check
   260 3105 E6 81		        inc plotX_hi            ; handle overflow from low to high byte
   261 				                                ; only reaches here if plotX_lo overflowed to 0
   262
   263 3107			lineloop_check:
   264 				        ; are we done? compare plotX to x2
   265 3107 A5 80		        lda plotX_lo            ; A = plotX_lo
   266 3109 C5 90		        cmp x2                  ; test: A = X2 ?
   267 310B D0 AE		        bne lineloop            ; not done, keep going
   268 				                                ; if plotX_lo != x2 JUMP BACK to lineloop
   269 310D A5 81		        lda plotX_hi            ; A = plotX_hi
   270 310F C5 91		        cmp x2_hi               ; test: A = x2_hi ?
   271 3111 D0 A8		        bne lineloop            ; not done, keep going
   272 				                                ; if plotX_hi != x2_hi JUMP BACK to lineloop
   273 				                                ; if both match we fall through - done!
   274
   275 				        
   276
   277 3113 60			        rts
   278 				        .endp
