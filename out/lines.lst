   145 				;=========================================================================================
   146 				; print a string
   147 				; Assumptions
   148 				; strptr_lo = low address of the string
   149 				; strptr_hi = high address of the string
   150 				;       together we have a 16-bit address of the string
   151
   152 				; Y = index of current character to process, starts at 0
   153 				; example calling code:
   154 				;       mva #1 csrhinh                  ; hide the cursor
   155 				;        mva #6 rowcrs                   ; set output row
   156 				;        mva #10 colcrs                  ; set output column
   157 				;        
   158 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   159 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   160 				;        jsr print_string                ; print the string
   161 				;
   162 				;========= don't forget you'll need data
   163 				;       .local string1
   164 				;        .byte 'HELLO FROM STRING ONE!',0
   165 				;        .endl
   166
   167 				;======================================================================
   168 3074			        .proc print_string
   169 3074 A0 00		        ldy #0
   170 3076			loop:
   171 3076 B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   172 3078 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   173 307A F0 0D		        beq exit                        ; if true, branch to exit
   174 307C 98			        tya                             ; A = Y
   175 307D 48			        pha                             ; push A onto the stack
   176 307E B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   177 3080 20 8D 30		        jsr putchar                     ; call putchar to write a character out
   178 3083 68			        pla                             ; A = pop stack
   179 3084 A8			        tay                             ; Y = A
   180 3085 C8			        iny                             ; Y = Y + 1
   181 3086 4C 76 30		        jmp loop                        ; GOTO loop
   182 3089			exit:
   183 3089 60			        rts                             ; exit subroutine
   184 				        .endp
   185
   186 308A			stop:
   187 308A 4C 8A 30		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   188 				;======================================================================
   189
   190 				; print a character
   191 				; Assumptions
   192 				; 1. the character is in register A
   193 				; 2. the character has been converted to ATASCII
   194 				; 3. before calling, save values of X and Y registers
   195
   196 308D			        .proc putchar
   197 308D AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   198 308E AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   199 3091 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   200 3092 AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   201 3095 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   202 3096 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   203 3097 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   204 				        .endp           ; end of putchar procedure
   205
   206 				;========================================================================================
   207 				        ; print both digits in base 10, from left to right
   208 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   209 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   210 				        ; Assumtions: A contains the hex value of the number to print
   211
   212 3098			        .proc printDecimal
   213 3098 A2 00		        ldx #0
   214 309A			checkCount:
   215 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   216 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   217 309A C9 0A		        cmp #10             ; Does A = 10?
   218 309C 90 07		        bcc doneCounting    ; branch if carry is cleared
   219 309E 38			        sec                 ; set carry
   220 309F E9 0A		        sbc #10             ; A = A - 10
   221 30A1 E8			        inx                 ; X = X + 1
   222 30A2 4C 9A 30		        jmp checkCount
   223
   224 30A5			doneCounting:   
   225 30A5 48			        pha                 ; push(A) (push A onto the stack)
   226 30A6 8A			        txa                 ; A = X
   227 30A7 18			        clc
   228 30A8 69 30		        adc #offset_to_char
   229 30AA 20 8D 30		        jsr putchar
   230
   231 30AD 68			        pla                 ; A = pop() (pop the next value off the stack)
   232 30AE 18			        clc 
   233 30AF 69 30		        adc #offset_to_char
   234 30B1 20 8D 30		        jsr putchar
   235 				        .endp
   236 				;==================================================================================================
   237
   238 				; plot a point (x,y)
   239 				; Step 1: Find which ROW we're on
   240 				;        plotY × 40 = how many bytes to skip to reach our row
   241 				;        (each row is 40 bytes wide)
   242 				;        2^3 + 2^2
   243 				; Step 2: Find which BYTE within that row
   244 				;        plotX ÷ 8 = which byte contains our pixel
   245 				;        (each byte holds 8 pixels)
   246 				;
   247 				; Step 3: Add them together
   248 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   249 				;
   250 				; Step 4: Add SAVMSC
   251 				;        SAVMSC + offset = actual address in memory of our byte
   252 				;
   253 				; Step 5: Find which BIT within that byte
   254 				;        7 - (plotX mod 8) = which bit is our pixel
   255 				;
   256 				; Step 6: Set that bit
   257 				;        read the byte
   258 				;        OR with our bit mask
   259 				;        write the byte back
   260 				;
   261 30B4			        .proc plotPoint
   262
   263 				        ; see multiplyingYby40.txt for full breakdown with an example!
   264
   265 				        ; defeat attract mode on every plot
   266 30B4 A9 00 85 4D		        mva #0    ATRACT
   267 30B8 A9 FF 85 4E		        mva #$FF  ATRMSK
   268
   269 				        ; Step 1: Find which ROW we're on
   270 30BC A5 82		        lda plotY
   271 30BE 85 83		        sta temp_lo         ; temp = plotY
   272 30C0 A9 00		        lda #0
   273 30C2 85 84		        sta temp_hi         ; high byte starts at 0
   274
   275 				        ; × 2
   276 30C4 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   277 30C6 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   278
   279 				        ; × 4
   280 30C8 06 83		        asl temp_lo
   281 30CA 26 84		        rol temp_hi
   282
   283 				        ; × 8  ← save this!
   284 30CC 06 83		        asl temp_lo
   285 30CE 26 84		        rol temp_hi
   286 30D0 A5 83		        lda temp_lo
   287 30D2 85 87		        sta save_lo
   288 30D4 A5 84		        lda temp_hi
   289 30D6 85 88		        sta save_hi
   290
   291 				        ; × 16
   292 30D8 06 83		        asl temp_lo
   293 30DA 26 84		        rol temp_hi
   294
   295 				        ; × 32
   296 30DC 06 83		        asl temp_lo
   297 30DE 26 84		        rol temp_hi
   298
   299 30E0 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   300 30E2 18			        clc                 ; clear carry
   301 30E3 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   302 30E5 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   303
   304 30E7 A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   305 30E9 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   306 30EB 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   307 				        ; we now have the offset to our target row in temp_lo and temp_hi
   308
   309 				        ; calculate which bit 
   310 30ED A5 80		        lda plotX_lo
   311 30EF 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   312 30F1 85 89		        sta bitpos          ; save for Step 5
   313
   314 				        ; Step 2: find offset from start of row to our pixel
   315 				        ; plotX ÷ 8 using 16-bit right shift
   316 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   317 				        ; ON EXIT:  A contains column byte offset (0-39)
   318 30F3 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   319 30F5 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   320
   321 30F7 46 81		        lsr plotX_hi        ; shift again
   322 30F9 66 80		        ror plotX_lo
   323
   324 30FB 46 81		        lsr plotX_hi        ; shift again
   325 30FD 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   326
   327 				        ; Step 3: add results from step 1 and 2 together
   328 30FF A5 83		        lda temp_lo
   329 3101 18			        clc
   330 3102 65 80		        adc plotX_lo
   331 3104 85 83		        sta temp_lo
   332
   333 3106 A5 84		        lda temp_hi
   334 3108 69 00		        adc #0
   335 310A 85 84		        sta temp_hi
   336 				        ; temp now contains total byte offset from SAVMSC
   337
   338 				        ; Step 4: Add SAVMSC Base Address
   339 310C A5 83		        lda temp_lo
   340 310E 18			        clc
   341 310F 65 58		        adc SAVMSC
   342 3111 85 85		        sta scrptr_lo
   343
   344 3113 A5 84		        lda temp_hi
   345 3115 65 59		        adc SAVMSC+1
   346 3117 85 86		        sta scrptr_hi
   347
   348 				        ; Step 5: find which bit to turn on
   349 				        ; algo:  bit position = 7 - (plotX mod 8)
   350 				        ; Step 5: find which bit to turn on
   351 3119 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   352 311B A6 89		        ldx bitpos          ; X = number of times to shift right
   353 311D F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   354 311F			shift_loop:
   355 311F 4A			        lsr                 ; shift A right one position
   356 3120 CA			        dex                 ; X = X - 1
   357 3121 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   358 3123			done_shift:
   359 				                            ; A now contains our bit mask
   360
   361 				        ; Step 6: turn on our bit!!
   362 3123 85 8A		        sta bitmask             ; save mask
   363 3125 A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   364 3127 B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   365 3129 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   366 312B 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   367
   368 312D 60			        rts
   369 				        .endp
   370 				;======================================================================
   371
   372 				; =====================================================================
   373 				; DATA
   374 				; =====================================================================
   375 312E 53 3A 9B		scrname .byte 'S:',$9B             ; device name string for CIO OPEN
   376 				                                    ; 'S:' = screen device
   377 				                                    ; $9B  = ATASCII end-of-line terminator
     3
     4 3131			        org $2000
     5
     6 2000			        .proc main
     7 				    
     8 				        ;=============================================================
     9 				        ; print a string example
