   281 				;=========================================================================================
   282 				; print a string
   283 				; Assumptions
   284 				; strptr_lo = low address of the string
   285 				; strptr_hi = high address of the string
   286 				;       together we have a 16-bit address of the string
   287
   288 				; Y = index of current character to process, starts at 0
   289 				; example calling code:
   290 				;       mva #1 csrhinh                  ; hide the cursor
   291 				;        mva #6 rowcrs                   ; set output row
   292 				;        mva #10 colcrs                  ; set output column
   293 				;        
   294 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   295 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   296 				;        jsr print_string                ; print the string
   297 				;
   298 				;========= don't forget you'll need data
   299 				;       .local string1
   300 				;        .byte 'HELLO FROM STRING ONE!',0
   301 				;        .endl
   302
   303 				;======================================================================
   304 3114			        .proc print_string
   305 3114 A0 00		        ldy #0
   306 3116			loop:
   307 3116 B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   308 3118 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   309 311A F0 0D		        beq exit                        ; if true, branch to exit
   310 311C 98			        tya                             ; A = Y
   311 311D 48			        pha                             ; push A onto the stack
   312 311E B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   313 3120 20 2D 31		        jsr putchar                     ; call putchar to write a character out
   314 3123 68			        pla                             ; A = pop stack
   315 3124 A8			        tay                             ; Y = A
   316 3125 C8			        iny                             ; Y = Y + 1
   317 3126 4C 16 31		        jmp loop                        ; GOTO loop
   318 3129			exit:
   319 3129 60			        rts                             ; exit subroutine
   320 				        .endp
   321
   322 312A			stop:
   323 312A 4C 2A 31		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   324 				;======================================================================
   325
   326 				; print a character
   327 				; Assumptions
   328 				; 1. the character is in register A
   329 				; 2. the character has been converted to ATASCII
   330 				; 3. before calling, save values of X and Y registers
   331
   332 312D			        .proc putchar
   333 312D AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   334 312E AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   335 3131 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   336 3132 AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   337 3135 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   338 3136 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   339 3137 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   340 				        .endp           ; end of putchar procedure
   341
   342 				;========================================================================================
   343 				        ; print both digits in base 10, from left to right
   344 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   345 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   346 				        ; Assumtions: A contains the hex value of the number to print
   347
   348 3138			        .proc printDecimal
   349 3138 A2 00		        ldx #0
   350 313A			checkCount:
   351 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   352 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   353 313A C9 0A		        cmp #10             ; Does A = 10?
   354 313C 90 07		        bcc doneCounting    ; branch if carry is cleared
   355 313E 38			        sec                 ; set carry
   356 313F E9 0A		        sbc #10             ; A = A - 10
   357 3141 E8			        inx                 ; X = X + 1
   358 3142 4C 3A 31		        jmp checkCount
   359
   360 3145			doneCounting:   
   361 3145 48			        pha                 ; push(A) (push A onto the stack)
   362 3146 8A			        txa                 ; A = X
   363 3147 18			        clc
   364 3148 69 30		        adc #offset_to_char
   365 314A 20 2D 31		        jsr putchar
   366
   367 314D 68			        pla                 ; A = pop() (pop the next value off the stack)
   368 314E 18			        clc 
   369 314F 69 30		        adc #offset_to_char
   370 3151 20 2D 31		        jsr putchar
   371 				        .endp
   372 				;==================================================================================================
   373
   374 				; plot a point (x,y)
   375 				; Step 1: Find which ROW we're on
   376 				;        plotY × 40 = how many bytes to skip to reach our row
   377 				;        (each row is 40 bytes wide)
   378 				;        2^3 + 2^2
   379 				; Step 2: Find which BYTE within that row
   380 				;        plotX ÷ 8 = which byte contains our pixel
   381 				;        (each byte holds 8 pixels)
   382 				;
   383 				; Step 3: Add them together
   384 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   385 				;
   386 				; Step 4: Add SAVMSC
   387 				;        SAVMSC + offset = actual address in memory of our byte
   388 				;
   389 				; Step 5: Find which BIT within that byte
   390 				;        7 - (plotX mod 8) = which bit is our pixel
   391 				;
   392 				; Step 6: Set that bit
   393 				;        read the byte
   394 				;        OR with our bit mask
   395 				;        write the byte back
   396 				;
   397 3154			        .proc plotPoint
   398
   399 				        ; see multiplyingYby40.txt for full breakdown with an example!
   400
   401 				        ; defeat attract mode on every plot
   402 3154 A9 00 85 4D		        mva #0    ATRACT
   403 3158 A9 FF 85 4E		        mva #$FF  ATRMSK
   404
   405 				        ; Step 1: Find which ROW we're on
   406 315C A5 82		        lda plotY
   407 315E 85 83		        sta temp_lo         ; temp = plotY
   408 3160 A9 00		        lda #0
   409 3162 85 84		        sta temp_hi         ; high byte starts at 0
   410
   411 				        ; × 2
   412 3164 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   413 3166 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   414
   415 				        ; × 4
   416 3168 06 83		        asl temp_lo
   417 316A 26 84		        rol temp_hi
   418
   419 				        ; × 8  ← save this!
   420 316C 06 83		        asl temp_lo
   421 316E 26 84		        rol temp_hi
   422 3170 A5 83		        lda temp_lo
   423 3172 85 87		        sta save_lo
   424 3174 A5 84		        lda temp_hi
   425 3176 85 88		        sta save_hi
   426
   427 				        ; × 16
   428 3178 06 83		        asl temp_lo
   429 317A 26 84		        rol temp_hi
   430
   431 				        ; × 32
   432 317C 06 83		        asl temp_lo
   433 317E 26 84		        rol temp_hi
   434
   435 3180 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   436 3182 18			        clc                 ; clear carry
   437 3183 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   438 3185 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   439
   440 3187 A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   441 3189 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   442 318B 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   443 				        ; we now have the offset to our target row in temp_lo and temp_hi
   444
   445 				        ; calculate which bit 
   446 318D A5 80		        lda plotX_lo
   447 318F 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   448 3191 85 89		        sta bitpos          ; save for Step 5
   449
   450 				        ; Step 2: find offset from start of row to our pixel
   451 				        ; plotX ÷ 8 using 16-bit right shift
   452 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   453 				        ; ON EXIT:  A contains column byte offset (0-39)
   454 3193 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   455 3195 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   456
   457 3197 46 81		        lsr plotX_hi        ; shift again
   458 3199 66 80		        ror plotX_lo
   459
   460 319B 46 81		        lsr plotX_hi        ; shift again
   461 319D 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   462
   463 				        ; Step 3: add results from step 1 and 2 together
   464 319F A5 83		        lda temp_lo
   465 31A1 18			        clc
   466 31A2 65 80		        adc plotX_lo
   467 31A4 85 83		        sta temp_lo
   468
   469 31A6 A5 84		        lda temp_hi
   470 31A8 69 00		        adc #0
   471 31AA 85 84		        sta temp_hi
   472 				        ; temp now contains total byte offset from SAVMSC
   473
   474 				        ; Step 4: Add SAVMSC Base Address
   475 31AC A5 83		        lda temp_lo
   476 31AE 18			        clc
   477 31AF 65 58		        adc SAVMSC
   478 31B1 85 85		        sta scrptr_lo
   479
   480 31B3 A5 84		        lda temp_hi
   481 31B5 65 59		        adc SAVMSC+1
   482 31B7 85 86		        sta scrptr_hi
   483
   484 				        ; Step 5: find which bit to turn on
   485 				        ; algo:  bit position = 7 - (plotX mod 8)
   486 				        ; Step 5: find which bit to turn on
   487 31B9 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   488 31BB A6 89		        ldx bitpos          ; X = number of times to shift right
   489 31BD F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   490 31BF			shift_loop:
   491 31BF 4A			        lsr                 ; shift A right one position
   492 31C0 CA			        dex                 ; X = X - 1
   493 31C1 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   494 31C3			done_shift:
   495 				                            ; A now contains our bit mask
   496
   497 				        ; Step 6: turn on our bit!!
   498 31C3 85 8A		        sta bitmask             ; save mask
   499 31C5 A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   500 31C7 B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   501 31C9 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   502 31CB 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   503
   504 31CD 60			        rts
   505 				        .endp
   506 				;======================================================================
   507
   508 				; =====================================================================
   509 				; DATA
   510 				; =====================================================================
   511 31CE 53 3A 9B		scrname .byte 'S:',$9B             ; device name string for CIO OPEN
   512 				                                    ; 'S:' = screen device
   513 				                                    ; $9B  = ATASCII end-of-line terminator
     3
     4 31D1			        org $2000
