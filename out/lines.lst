     5 				;=========================================================================================
     6 				; draw a circle using Bresenham's circle algorithm
     7 				; ON ENTRY: cx/cx_hi = center X, cy = center Y, radius = radius
     8 				; ON EXIT:  circle drawn on screen
     9
    10 				        .proc drawCircle
    11
    12 				        ; initialize error term: cerr = 1 - radius
    13 FFFF> 3000-32D9> A9 01	        lda #1
    14 3002 38			        sec
    15 3003 E5 9E		        sbc radius
    16 3005 85 A1		        sta cerr_lo
    17 3007 A9 00		        lda #0
    18 3009 E9 00		        sbc #0
    19 300B 85 A2		        sta cerr_hi
    20
    21 				        ; initialize offsets
    22 300D A9 00 85 9F		        mva #0  circX       ; circX = 0
    23 3011 A5 9E		        lda radius
    24 3013 85 A0		        sta circY           ; circY = radius
    25
    26 3015			circleloop:
    27
    28 				        ; plot point 1: (cx + circX, cy + circY)
    29 3015 A5 9B		        lda cx
    30 3017 18			        clc
    31 3018 65 9F		        adc circX
    32 301A 85 80		        sta plotX_lo
    33 301C A5 9C		        lda cx_hi
    34 301E 69 00		        adc #0
    35 3020 85 81		        sta plotX_hi
    36 3022 A5 9D		        lda cy
    37 3024 18			        clc
    38 3025 65 A0		        adc circY
    39 3027 85 82		        sta plotY
    40 3029 20 5D 32		        jsr plotPoint
    41
    42 				        ; plot point 2: (cx - circX, cy + circY)
    43 302C A5 9B		        lda cx
    44 302E 38			        sec
    45 302F E5 9F		        sbc circX
    46 3031 85 80		        sta plotX_lo
    47 3033 A5 9C		        lda cx_hi
    48 3035 E9 00		        sbc #0
    49 3037 85 81		        sta plotX_hi
    50 3039 A5 9D		        lda cy
    51 303B 18			        clc
    52 303C 65 A0		        adc circY
    53 303E 85 82		        sta plotY
    54 3040 20 5D 32		        jsr plotPoint
    55
    56 				        ; plot point 3: (cx + circX, cy - circY)
    57 3043 A5 9B		        lda cx
    58 3045 18			        clc
    59 3046 65 9F		        adc circX
    60 3048 85 80		        sta plotX_lo
    61 304A A5 9C		        lda cx_hi
    62 304C 69 00		        adc #0
    63 304E 85 81		        sta plotX_hi
    64 3050 A5 9D		        lda cy
    65 3052 38			        sec
    66 3053 E5 A0		        sbc circY
    67 3055 85 82		        sta plotY
    68 3057 20 5D 32		        jsr plotPoint
    69
    70 				        ; plot point 4: (cx - circX, cy - circY)
    71 305A A5 9B		        lda cx
    72 305C 38			        sec
    73 305D E5 9F		        sbc circX
    74 305F 85 80		        sta plotX_lo
    75 3061 A5 9C		        lda cx_hi
    76 3063 E9 00		        sbc #0
    77 3065 85 81		        sta plotX_hi
    78 3067 A5 9D		        lda cy
    79 3069 38			        sec
    80 306A E5 A0		        sbc circY
    81 306C 85 82		        sta plotY
    82 306E 20 5D 32		        jsr plotPoint
    83
    84 				        ; plot point 5: (cx + circY, cy + circX)
    85 3071 A5 9B		        lda cx
    86 3073 18			        clc
    87 3074 65 A0		        adc circY
    88 3076 85 80		        sta plotX_lo
    89 3078 A5 9C		        lda cx_hi
    90 307A 69 00		        adc #0
    91 307C 85 81		        sta plotX_hi
    92 307E A5 9D		        lda cy
    93 3080 18			        clc
    94 3081 65 9F		        adc circX
    95 3083 85 82		        sta plotY
    96 3085 20 5D 32		        jsr plotPoint
    97
    98 				        ; plot point 6: (cx - circY, cy + circX)
    99 3088 A5 9B		        lda cx
   100 308A 38			        sec
   101 308B E5 A0		        sbc circY
   102 308D 85 80		        sta plotX_lo
   103 308F A5 9C		        lda cx_hi
   104 3091 E9 00		        sbc #0
   105 3093 85 81		        sta plotX_hi
   106 3095 A5 9D		        lda cy
   107 3097 18			        clc
   108 3098 65 9F		        adc circX
   109 309A 85 82		        sta plotY
   110 309C 20 5D 32		        jsr plotPoint
   111
   112 				        ; plot point 7: (cx + circY, cy - circX)
   113 309F A5 9B		        lda cx
   114 30A1 18			        clc
   115 30A2 65 A0		        adc circY
   116 30A4 85 80		        sta plotX_lo
   117 30A6 A5 9C		        lda cx_hi
   118 30A8 69 00		        adc #0
   119 30AA 85 81		        sta plotX_hi
   120 30AC A5 9D		        lda cy
   121 30AE 38			        sec
   122 30AF E5 9F		        sbc circX
   123 30B1 85 82		        sta plotY
   124 30B3 20 5D 32		        jsr plotPoint
   125
   126 				        ; plot point 8: (cx - circY, cy - circX)
   127 30B6 A5 9B		        lda cx
   128 30B8 38			        sec
   129 30B9 E5 A0		        sbc circY
   130 30BB 85 80		        sta plotX_lo
   131 30BD A5 9C		        lda cx_hi
   132 30BF E9 00		        sbc #0
   133 30C1 85 81		        sta plotX_hi
   134 30C3 A5 9D		        lda cy
   135 30C5 38			        sec
   136 30C6 E5 9F		        sbc circX
   137 30C8 85 82		        sta plotY
   138 30CA 20 5D 32		        jsr plotPoint
   139
   140 				        ; advance circX
   141 30CD E6 9F		        inc circX
   142
   143 				        ; check sign of cerr
   144 30CF A5 A2		        lda cerr_hi
   145 30D1 30 19		        bmi update_negative     ; cerr < 0
   146
   147 				        ; positive path: cerr >= 0
   148 30D3 C6 A0		        dec circY               ; circY = circY - 1
   149 30D5 A5 9F		        lda circX
   150 30D7 38			        sec
   151 30D8 E5 A0		        sbc circY               ; A = circX - circY
   152 30DA 0A			        asl                     ; A = 2*(circX-circY)
   153 30DB 18			        clc
   154 30DC 69 01		        adc #1                  ; A = 2*(circX-circY) + 1
   155 30DE 18			        clc
   156 30DF 65 A1		        adc cerr_lo
   157 30E1 85 A1		        sta cerr_lo
   158 30E3 A5 A2		        lda cerr_hi
   159 30E5 69 00		        adc #0
   160 30E7 85 A2		        sta cerr_hi
   161 30E9 4C FD 30		        jmp check_done          ; skip negative path
   162
   163 30EC			update_negative:
   164 				        ; negative path: cerr < 0
   165 30EC A5 9F		        lda circX
   166 30EE 0A			        asl                     ; A = 2*circX
   167 30EF 18			        clc
   168 30F0 69 01		        adc #1                  ; A = 2*circX + 1
   169 30F2 18			        clc
   170 30F3 65 A1		        adc cerr_lo
   171 30F5 85 A1		        sta cerr_lo
   172 30F7 A5 A2		        lda cerr_hi
   173 30F9 69 00		        adc #0
   174 30FB 85 A2		        sta cerr_hi
   175 				                                ; fall through to check_done
   176
   177 30FD			check_done:
   178 30FD A5 9F		        lda circX
   179 30FF C5 A0		        cmp circY
   180 3101 90 03		        bcc keep_going      ; circX < circY — short forward branch
   181 3103 F0 01		        beq keep_going      ; circX = circY — short forward branch
   182 3105 60			        rts                 ; circX > circY — done!
   183 3106			keep_going:
   184 3106 4C 15 30		        jmp circleloop      ; jump back — unlimited range
   185 				        .endp
   186
   187
   188 				; =====================================================================
   189 				; fightAttract
   190 				; Call this every frame in your stop loop to prevent attract mode
   191 				; from desaturating your colors
   192 				; ON ENTRY: nothing
   193 				; ON EXIT:  attract mode defeated for this frame
   194 				;======================================================================
   195 3109			        .proc fightAttract
   196
   197 				        ; defeat attract mode and set colors
   198 3109 A9 00 85 4D		        mva #0    ATRACT
   199 310D A9 FF 85 4E		        mva #$FF  ATRMSK
   200
   201 3111 60			        rts
   202 				        .endp
   203
   204 				; =====================================================================
   205 				; Clear the screen
   206
   207 3112			        .proc clearScreen
   208
   209 				; initialize pointer from SAVMSC
   210 3112 A5 58		        lda SAVMSC
   211 3114 85 85		        sta scrptr_lo
   212 3116 A5 59		        lda SAVMSC+1
   213 3118 85 86		        sta scrptr_hi
   214
   215 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
   216 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
   217 				; because Y equals zero — exiting the inner loop into the outer loop.
   218
   219 311A A2 1E		        ldx #30             ; X = 30 pages to clear
   220 311C A0 00		        ldy #0              ; Y = byte index within page
   221
   222 311E			clearpage:
   223 311E A9 00		        lda #$00
   224 3120 91 85		        sta (scrptr_lo),y   ; write $00
   225 3122 C8			        iny                 ; next byte
   226 3123 D0 F9		        bne clearpage       ; inner loop — 256 bytes
   227
   228 3125 E6 86		        inc scrptr_hi       ; advance to next page
   229 3127 CA			        dex                 ; X = X - 1
   230 3128 D0 F4		        bne clearpage       ; outer loop — 30 pages
   231
   232 312A 60			        rts
   233 				        .endp
   234
   235
   236 				; =====================================================================
   237 				; Open Graphics Mode 8
   238
   239 312B			        .proc openGR8
   240
   241 				; =====================================================================
   242 				; STEP 1: Close IOCB6
   243 				; Good practice to close before opening — ensures clean state.
   244 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
   245 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
   246 				; ON EXIT:  IOCB6 is closed and ready to be reopened
   247 				; =====================================================================
   248 312B A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   249 312D A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
   250 312F 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
   251 3132 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
   252
   253 				; =====================================================================
   254 				; STEP 2: Open Graphics Mode 8
   255 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
   256 				; CIO sets up the display list, allocates screen RAM, configures
   257 				; ANTIC — everything needed for graphics mode automatically.
   258 				; ON ENTRY: nothing required
   259 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
   260 				; =====================================================================
   261
   262
   263 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 8
   264 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
   265 				;   pixel data directly to screen RAM.
   266 				;   GR.8:   320 pixels wide × 192 tall   1 bit per pixel     2 colors
   267 				;   GR.8:   40 bytes × 192 rows = 7,680 bytes
   268 				;   GR.8:   320 pixels ÷ 8 pixels per byte = 40 bytes per row
   269 				;   GR.8 byte:  P P P P P P P P
   270 				;               | | | | | | | |
   271 				;               7 6 5 4 3 2 1 0   (8 pixels, 1 bit each, on or off)
   272
   273 3135 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   274 3137 A9 03		        lda #$03                    ; A = $03        (OPEN command)
   275 3139 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
   276 313C A9 D7		        lda #<scrname               ; A = low byte of "S:" string address
   277 313E 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
   278 3141 A9 32		        lda #>scrname               ; A = high byte of "S:" string address
   279 3143 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
   280 3146 A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
   281 3148 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
   282 314B A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   283 314D 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   284 3150 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   285
   286 				; Step 3: Setup color registers
   287 				; change COLPF1 to change pixel color
   288
   289 3153 A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
   290 3158 A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
   291 315D A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
   292
   293 3162 60			        rts
   294 				        .endp
   295
   296 				;=========================================================================================
   297 				; draw a line using Bresenham's algorithm
   298
   299 3163			        .proc drawLine
   300
   301 				        ; first step, compute:
   302 				        ; dx = x2 - x1    (16-bit subtraction)
   303 				        ; dy = y2 - y1    (8-bit subtraction)
   304
   305 3163 A5 92		        lda y2          ; A = Y2
   306 3165 38			        sec             ; set carry
   307 3166 E5 8F		        sbc y1          ; A = A - Y1
   308 3168 85 95		        sta dy          ; dy = A
   309
   310 316A A5 90		        lda x2          ; A = x2 (low byte)
   311 316C 38			        sec             ; set carry
   312 316D E5 8D		        sbc x1          ; A = A - X1 (low byte)
   313 316F 85 93		        sta dx_lo       ; save low byte, but do not re-set carry
   314
   315 3171 A5 91		        lda x2_hi       ; A = X2 (high byte)
   316 3173 E5 8E		        sbc x1_hi       ; A = A - X1 (high byte)
   317 3175 85 94		        sta dx_hi       ; save high byte
   318
   319 				        ; check for vertical line (dx = 0)
   320 3177 A5 93		        lda dx_lo
   321 3179 05 94		        ora dx_hi       ; OR low and high bytes together
   322 317B D0 33		        bne not_vertical ; if result != 0, not vertical
   323
   324 				        ; handle vertical line
   325 				        ; initialize position first!
   326 317D A5 8D		        lda x1
   327 317F 85 80		        sta plotX_lo
   328 3181 A5 8E		        lda x1_hi
   329 3183 85 81		        sta plotX_hi
   330 3185 A5 8F		        lda y1
   331 3187 85 82		        sta plotY
   332
   333 				        ; just loop Y from y1 to y2
   334 3189			vertical_loop:
   335 3189 A5 80		        lda plotX_lo    ; save plotX before plotPoint destroys it
   336 318B 48			        pha
   337 318C A5 81		        lda plotX_hi
   338 318E 48			        pha
   339 				        
   340 318F 20 5D 32		        jsr plotPoint
   341 				        
   342 3192 68			        pla             ; restore plotX
   343 3193 85 81		        sta plotX_hi
   344 3195 68			        pla
   345 3196 85 80		        sta plotX_lo
   346 				        
   347 3198 E6 82		        inc plotY
   348 319A A5 82		        lda plotY
   349 319C C5 92		        cmp y2
   350 319E D0 E9		        bne vertical_loop
   351 				        
   352 				        ; plot final point
   353 31A0 A5 80		        lda plotX_lo
   354 31A2 48			        pha
   355 31A3 A5 81		        lda plotX_hi
   356 31A5 48			        pha
   357 31A6 20 5D 32		        jsr plotPoint
   358 31A9 68			        pla
   359 31AA 85 81		        sta plotX_hi
   360 31AC 68			        pla
   361 31AD 85 80		        sta plotX_lo
   362 				        
   363 31AF 60			        rts
   364
   365 31B0			not_vertical:
   366 				        ; continue with normal Bresenham...
   367
   368 				        ; initialize current position to start point
   369 31B0 A5 8D		        lda x1          ; A = X1
   370 31B2 85 80		        sta plotX_lo    ; plotX_lo = A
   371 31B4 A5 8E		        lda x1_hi       ; A = X1_hi
   372 31B6 85 81		        sta plotX_hi    ; plotX_hi = A
   373 31B8 A5 8F		        lda y1          ; A = Y1
   374 31BA 85 82		        sta plotY       ; plotY = A
   375
   376 				        ; initialize error to 0
   377 31BC A9 00 85 96		        mva #0 err_lo           ; err_lo = 0
   378 31C0 A9 00 85 97		        mva #0 err_hi           ; err_hi = 0
   379
   380 31C4			lineloop:
   381 				        ; save plotX before plotPoint destroys it
   382 31C4 A5 80		        lda plotX_lo
   383 31C6 48			        pha
   384 31C7 A5 81		        lda plotX_hi
   385 31C9 48			        pha
   386
   387 31CA 20 5D 32		        jsr plotPoint
   388
   389 				        ; restore plotX after plotPoint
   390 31CD 68			        pla
   391 31CE 85 81		        sta plotX_hi
   392 31D0 68			        pla
   393 31D1 85 80		        sta plotX_lo
   394
   395 				; add dy to error accumulator (16-bit + 8-bit addition)
   396 31D3 A5 96		        lda err_lo              ; A = err_lo
   397 31D5 18			        clc                     ; clear carry
   398 31D6 65 95		        adc dy                  ; A += dy
   399 31D8 85 96		        sta err_lo              ; err_lo = A
   400 31DA A5 97		        lda err_hi              ; A = err_hi
   401 31DC 69 00		        adc #0                  ; propagate carry trick. if the carry was set it gets added to the high byte
   402 31DE 85 97		        sta err_hi              ; err_hi = A
   403
   404 				        ; check if error * 2 >= dx
   405 				        ; compute error + error (16-bit)
   406 31E0 A5 96		        lda err_lo              ; A = err_lo
   407 31E2 18			        clc                     ; clear carry
   408 31E3 65 96		        adc err_lo              ; A += err_lo (err_lo * 2)
   409 31E5 85 83		        sta temp_lo             ; temp_lo = A
   410 31E7 A5 97		        lda err_hi              ; A = err_hi
   411 31E9 65 97		        adc err_hi              ; A += err_hi ((err_hi * 2) + carry)
   412 31EB 85 84		        sta temp_hi             ; temp_hi = A
   413
   414 				        ; compare temp (error*2) to dx
   415 				        ; 16-bit comparison: check high byte first, then low byte
   416 31ED A5 84		        lda temp_hi     ; A = temp_hi
   417 31EF C5 94		        cmp dx_hi       ; Does temp_hi == dx_hi? 
   418 31F1 90 17		        bcc skip_y      ; temp_hi < dx_hi, no Y step needed (branch if carry is clear)
   419 31F3 D0 06		        bne do_y_step   ; temp_hi > dx_hi, Y step needed (branch if not equal)
   420 31F5 A5 83		        lda temp_lo     ; A = temp_lo (high bytes equal, check low bytes (if we got here, high bytes are equal))
   421 31F7 C5 93		        cmp dx_lo       ; Does temp_lo == dx_lo?
   422 31F9 90 0F		        bcc skip_y      ; temp_lo < dx_lo, no Y step needed
   423
   424 31FB			do_y_step:
   425 31FB E6 82		        inc plotY       ; y = y + 1
   426
   427 				        ; error = error - dx (16-bit subtraction)
   428 31FD A5 96		        lda err_lo      ; A = err_lo
   429 31FF 38			        sec             ; set the carry
   430 3200 E5 93		        sbc dx_lo       ; A -= dx_lo
   431 3202 85 96		        sta err_lo      ; err_lo = A
   432 3204 A5 97		        lda err_hi      ; A = err_hi
   433 3206 E5 94		        sbc dx_hi       ; A -= dex_hi
   434 3208 85 97		        sta err_hi      ; err_hi = A
   435
   436 320A			skip_y:
   437 				        ; advance x (16-bit increment)
   438 320A E6 80		        inc plotX_lo            ; plotX_lo++
   439 320C D0 02		        bne lineloop_check      ; if no overflow, check if done 
   440 				                                ; if plotX_lo != 0 JUMP FORWARD to lineloop_check
   441 320E E6 81		        inc plotX_hi            ; handle overflow from low to high byte
   442 				                                ; only reaches here if plotX_lo overflowed to 0
   443
   444 3210			lineloop_check:
   445 				        ; are we done? compare plotX to x2
   446 3210 A5 80		        lda plotX_lo            ; A = plotX_lo
   447 3212 C5 90		        cmp x2                  ; test: A = X2 ?
   448 3214 D0 AE		        bne lineloop            ; not done, keep going
   449 				                                ; if plotX_lo != x2 JUMP BACK to lineloop
   450 3216 A5 81		        lda plotX_hi            ; A = plotX_hi
   451 3218 C5 91		        cmp x2_hi               ; test: A = x2_hi ?
   452 321A D0 A8		        bne lineloop            ; not done, keep going
   453 				                                ; if plotX_hi != x2_hi JUMP BACK to lineloop
   454 				                                ; if both match we fall through - done!
   455
   456 				        
   457
   458 321C 60			        rts
   459 				        .endp
   460
   461
   462 				;=========================================================================================
   463 				; print a string
   464 				; Assumptions
   465 				; strptr_lo = low address of the string
   466 				; strptr_hi = high address of the string
   467 				;       together we have a 16-bit address of the string
   468
   469 				; Y = index of current character to process, starts at 0
   470 				; example calling code:
   471 				;       mva #1 csrhinh                  ; hide the cursor
   472 				;        mva #6 rowcrs                   ; set output row
   473 				;        mva #10 colcrs                  ; set output column
   474 				;        
   475 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   476 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   477 				;        jsr print_string                ; print the string
   478 				;
   479 				;========= don't forget you'll need data
   480 				;       .local string1
   481 				;        .byte 'HELLO FROM STRING ONE!',0
   482 				;        .endl
   483
   484 				;======================================================================
   485 321D			        .proc print_string
   486 321D A0 00		        ldy #0
   487 321F			loop:
   488 321F B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   489 3221 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   490 3223 F0 0D		        beq exit                        ; if true, branch to exit
   491 3225 98			        tya                             ; A = Y
   492 3226 48			        pha                             ; push A onto the stack
   493 3227 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   494 3229 20 36 32		        jsr putchar                     ; call putchar to write a character out
   495 322C 68			        pla                             ; A = pop stack
   496 322D A8			        tay                             ; Y = A
   497 322E C8			        iny                             ; Y = Y + 1
   498 322F 4C 1F 32		        jmp loop                        ; GOTO loop
   499 3232			exit:
   500 3232 60			        rts                             ; exit subroutine
   501 				        .endp
   502
   503 3233			stop:
   504 3233 4C 33 32		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   505 				;======================================================================
   506
   507 				; print a character
   508 				; Assumptions
   509 				; 1. the character is in register A
   510 				; 2. the character has been converted to ATASCII
   511 				; 3. before calling, save values of X and Y registers
   512
   513 3236			        .proc putchar
   514 3236 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   515 3237 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   516 323A 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   517 323B AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   518 323E 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   519 323F 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   520 3240 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   521 				        .endp           ; end of putchar procedure
   522
   523 				;========================================================================================
   524 				        ; print both digits in base 10, from left to right
   525 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   526 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   527 				        ; Assumtions: A contains the hex value of the number to print
   528
   529 3241			        .proc printDecimal
   530 3241 A2 00		        ldx #0
   531 3243			checkCount:
   532 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   533 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   534 3243 C9 0A		        cmp #10             ; Does A = 10?
   535 3245 90 07		        bcc doneCounting    ; branch if carry is cleared
   536 3247 38			        sec                 ; set carry
   537 3248 E9 0A		        sbc #10             ; A = A - 10
   538 324A E8			        inx                 ; X = X + 1
   539 324B 4C 43 32		        jmp checkCount
   540
   541 324E			doneCounting:   
   542 324E 48			        pha                 ; push(A) (push A onto the stack)
   543 324F 8A			        txa                 ; A = X
   544 3250 18			        clc
   545 3251 69 30		        adc #offset_to_char
   546 3253 20 36 32		        jsr putchar
   547
   548 3256 68			        pla                 ; A = pop() (pop the next value off the stack)
   549 3257 18			        clc 
   550 3258 69 30		        adc #offset_to_char
   551 325A 20 36 32		        jsr putchar
   552 				        .endp
   553 				;==================================================================================================
   554
   555 				; plot a point (x,y)
   556 				; Step 1: Find which ROW we're on
   557 				;        plotY × 40 = how many bytes to skip to reach our row
   558 				;        (each row is 40 bytes wide)
   559 				;        2^3 + 2^2
   560 				; Step 2: Find which BYTE within that row
   561 				;        plotX ÷ 8 = which byte contains our pixel
   562 				;        (each byte holds 8 pixels)
   563 				;
   564 				; Step 3: Add them together
   565 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   566 				;
   567 				; Step 4: Add SAVMSC
   568 				;        SAVMSC + offset = actual address in memory of our byte
   569 				;
   570 				; Step 5: Find which BIT within that byte
   571 				;        7 - (plotX mod 8) = which bit is our pixel
   572 				;
   573 				; Step 6: Set that bit
   574 				;        read the byte
   575 				;        OR with our bit mask
   576 				;        write the byte back
   577 				;
   578 325D			        .proc plotPoint
   579
   580 				        ; see multiplyingYby40.txt for full breakdown with an example!
   581
   582 				        ; defeat attract mode on every plot
   583 325D A9 00 85 4D		        mva #0    ATRACT
   584 3261 A9 FF 85 4E		        mva #$FF  ATRMSK
   585
   586 				        ; Step 1: Find which ROW we're on
   587 3265 A5 82		        lda plotY
   588 3267 85 83		        sta temp_lo         ; temp = plotY
   589 3269 A9 00		        lda #0
   590 326B 85 84		        sta temp_hi         ; high byte starts at 0
   591
   592 				        ; × 2
   593 326D 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   594 326F 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   595
   596 				        ; × 4
   597 3271 06 83		        asl temp_lo
   598 3273 26 84		        rol temp_hi
   599
   600 				        ; × 8  ← save this!
   601 3275 06 83		        asl temp_lo
   602 3277 26 84		        rol temp_hi
   603 3279 A5 83		        lda temp_lo
   604 327B 85 87		        sta save_lo
   605 327D A5 84		        lda temp_hi
   606 327F 85 88		        sta save_hi
   607
   608 				        ; × 16
   609 3281 06 83		        asl temp_lo
   610 3283 26 84		        rol temp_hi
   611
   612 				        ; × 32
   613 3285 06 83		        asl temp_lo
   614 3287 26 84		        rol temp_hi
   615
   616 3289 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   617 328B 18			        clc                 ; clear carry
   618 328C 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   619 328E 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   620
   621 3290 A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   622 3292 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   623 3294 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   624 				        ; we now have the offset to our target row in temp_lo and temp_hi
   625
   626 				        ; calculate which bit 
   627 3296 A5 80		        lda plotX_lo
   628 3298 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   629 329A 85 89		        sta bitpos          ; save for Step 5
   630
   631 				        ; Step 2: find offset from start of row to our pixel
   632 				        ; plotX ÷ 8 using 16-bit right shift
   633 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   634 				        ; ON EXIT:  A contains column byte offset (0-39)
   635 329C 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   636 329E 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   637
   638 32A0 46 81		        lsr plotX_hi        ; shift again
   639 32A2 66 80		        ror plotX_lo
   640
   641 32A4 46 81		        lsr plotX_hi        ; shift again
   642 32A6 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   643
   644 				        ; Step 3: add results from step 1 and 2 together
   645 32A8 A5 83		        lda temp_lo
   646 32AA 18			        clc
   647 32AB 65 80		        adc plotX_lo
   648 32AD 85 83		        sta temp_lo
   649
   650 32AF A5 84		        lda temp_hi
   651 32B1 69 00		        adc #0
   652 32B3 85 84		        sta temp_hi
   653 				        ; temp now contains total byte offset from SAVMSC
   654
   655 				        ; Step 4: Add SAVMSC Base Address
   656 32B5 A5 83		        lda temp_lo
   657 32B7 18			        clc
   658 32B8 65 58		        adc SAVMSC
   659 32BA 85 85		        sta scrptr_lo
   660
   661 32BC A5 84		        lda temp_hi
   662 32BE 65 59		        adc SAVMSC+1
   663 32C0 85 86		        sta scrptr_hi
   664
   665 				        ; Step 5: find which bit to turn on
   666 				        ; algo:  bit position = 7 - (plotX mod 8)
   667 				        ; Step 5: find which bit to turn on
   668 32C2 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   669 32C4 A6 89		        ldx bitpos          ; X = number of times to shift right
   670 32C6 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   671 32C8			shift_loop:
   672 32C8 4A			        lsr                 ; shift A right one position
   673 32C9 CA			        dex                 ; X = X - 1
   674 32CA D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   675 32CC			done_shift:
   676 				                            ; A now contains our bit mask
   677
   678 				        ; Step 6: turn on our bit!!
   679 32CC 85 8A		        sta bitmask             ; save mask
   680 32CE A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   681 32D0 B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   682 32D2 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   683 32D4 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   684
   685 32D6 60			        rts
   686 				        .endp
   687 				;======================================================================
   688
