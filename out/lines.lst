    59 205B A9 01 85 8E		        mva #$01  x1_hi
    60 205F A9 00 85 8F		        mva #0    y1
    61 2063 A9 3F 85 90		        mva #$3F  x2
    62 2067 A9 01 85 91		        mva #$01  x2_hi
