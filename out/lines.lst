    41 2025 A9 00 85 8E		        mva #0    x1_hi
    42 2029 A9 BF 85 8F		        mva #191  y1
    43 202D A9 3F 85 90		        mva #$3F  x2
    44 2031 A9 01 85 91		        mva #$01  x2_hi
    45 2035 A9 BF 85 92		        mva #191  y2
