   103 				;=========================================================================================
   104
   105 				; print a string
   106 				; Assumptions
   107 				; strptr_lo = low address of the string
   108 				; strptr_hi = high address of the string
   109 				;       together we have a 16-bit address of the string
   110
   111 				; Y = index of current character to process, starts at 0
   112 				; example calling code:
   113 				;       mva #1 csrhinh                  ; hide the cursor
   114 				;        mva #6 rowcrs                   ; set output row
   115 				;        mva #10 colcrs                  ; set output column
   116 				;        
   117 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   118 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   119 				;        jsr print_string                ; print the string
   120 				;
   121 				;========= don't forget you'll need data
   122 				;       .local string1
   123 				;        .byte 'HELLO FROM STRING ONE!',0
   124 				;        .endl
   125
   126 				;======================================================================
   127 305A			        .proc print_string
   128 305A A0 00		        ldy #0
   129 305C			loop:
   130 305C B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   131 305E C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   132 3060 F0 0D		        beq exit                        ; if true, branch to exit
   133 3062 98			        tya                             ; A = Y
   134 3063 48			        pha                             ; push A onto the stack
   135 3064 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   136 3066 20 73 30		        jsr putchar                     ; call putchar to write a character out
   137 3069 68			        pla                             ; A = pop stack
   138 306A A8			        tay                             ; Y = A
   139 306B C8			        iny                             ; Y = Y + 1
   140 306C 4C 5C 30		        jmp loop                        ; GOTO loop
   141 306F			exit:
   142 306F 60			        rts                             ; exit subroutine
   143 				        .endp
   144
   145 3070			stop:
   146 3070 4C 70 30		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   147 				;======================================================================
   148
   149 				; print a character
   150 				; Assumptions
   151 				; 1. the character is in register A
   152 				; 2. the character has been converted to ATASCII
   153 				; 3. before calling, save values of X and Y registers
   154
   155 3073			        .proc putchar
   156 3073 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   157 3074 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   158 3077 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   159 3078 AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   160 307B 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   161 307C 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   162 307D 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   163 				        .endp           ; end of putchar procedure
   164
   165 				;========================================================================================
   166 				        ; print both digits in base 10, from left to right
   167 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   168 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   169 				        ; Assumtions: A contains the hex value of the number to print
   170
   171 307E			        .proc printDecimal
   172 307E A2 00		        ldx #0
   173 3080			checkCount:
   174 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   175 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   176 3080 C9 0A		        cmp #10             ; Does A = 10?
   177 3082 90 07		        bcc doneCounting    ; branch if carry is cleared
   178 3084 38			        sec                 ; set carry
   179 3085 E9 0A		        sbc #10             ; A = A - 10
   180 3087 E8			        inx                 ; X = X + 1
   181 3088 4C 80 30		        jmp checkCount
   182
   183 308B			doneCounting:   
   184 308B 48			        pha                 ; push(A) (push A onto the stack)
   185 308C 8A			        txa                 ; A = X
   186 308D 18			        clc
   187 308E 69 30		        adc #offset_to_char
   188 3090 20 73 30		        jsr putchar
   189
   190 3093 68			        pla                 ; A = pop() (pop the next value off the stack)
   191 3094 18			        clc 
   192 3095 69 30		        adc #offset_to_char
   193 3097 20 73 30		        jsr putchar
   194 				        .endp
   195 				;==================================================================================================
   196
   197 				; plot a point (x,y)
   198 				; Step 1: Find which ROW we're on
   199 				;        plotY × 40 = how many bytes to skip to reach our row
   200 				;        (each row is 40 bytes wide)
   201 				;        2^3 + 2^2
   202 				; Step 2: Find which BYTE within that row
   203 				;        plotX ÷ 8 = which byte contains our pixel
   204 				;        (each byte holds 8 pixels)
   205 				;
   206 				; Step 3: Add them together
   207 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   208 				;
   209 				; Step 4: Add SAVMSC
   210 				;        SAVMSC + offset = actual address in memory of our byte
   211 				;
   212 				; Step 5: Find which BIT within that byte
   213 				;        7 - (plotX mod 8) = which bit is our pixel
   214 				;
   215 				; Step 6: Set that bit
   216 				;        read the byte
   217 				;        OR with our bit mask
   218 				;        write the byte back
   219 				;
   220 309A			        .proc plotPoint
   221
   222 				        ; see multiplyingYby40.txt for full breakdown with an example!
   223
   224 				        ; defeat attract mode on every plot
   225 309A A9 00 85 4D		        mva #0    ATRACT
   226 309E A9 FF 85 4E		        mva #$FF  ATRMSK
   227
   228 				        ; Step 1: Find which ROW we're on
   229 30A2 A5 82		        lda plotY
   230 30A4 85 83		        sta temp_lo         ; temp = plotY
   231 30A6 A9 00		        lda #0
   232 30A8 85 84		        sta temp_hi         ; high byte starts at 0
   233
   234 				        ; × 2
   235 30AA 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   236 30AC 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   237
   238 				        ; × 4
   239 30AE 06 83		        asl temp_lo
   240 30B0 26 84		        rol temp_hi
   241
   242 				        ; × 8  ← save this!
   243 30B2 06 83		        asl temp_lo
   244 30B4 26 84		        rol temp_hi
   245 30B6 A5 83		        lda temp_lo
   246 30B8 85 87		        sta save_lo
   247 30BA A5 84		        lda temp_hi
   248 30BC 85 88		        sta save_hi
   249
   250 				        ; × 16
   251 30BE 06 83		        asl temp_lo
   252 30C0 26 84		        rol temp_hi
   253
   254 				        ; × 32
   255 30C2 06 83		        asl temp_lo
   256 30C4 26 84		        rol temp_hi
   257
   258 30C6 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   259 30C8 18			        clc                 ; clear carry
   260 30C9 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   261 30CB 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   262
   263 30CD A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   264 30CF 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   265 30D1 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   266 				        ; we now have the offset to our target row in temp_lo and temp_hi
   267
   268 				        ; calculate which bit 
   269 30D3 A5 80		        lda plotX_lo
   270 30D5 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   271 30D7 85 89		        sta bitpos          ; save for Step 5
   272
   273 				        ; Step 2: find offset from start of row to our pixel
   274 				        ; plotX ÷ 8 using 16-bit right shift
   275 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   276 				        ; ON EXIT:  A contains column byte offset (0-39)
   277 30D9 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   278 30DB 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   279
   280 30DD 46 81		        lsr plotX_hi        ; shift again
   281 30DF 66 80		        ror plotX_lo
   282
   283 30E1 46 81		        lsr plotX_hi        ; shift again
   284 30E3 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   285
   286 				        ; Step 3: add results from step 1 and 2 together
   287 30E5 A5 83		        lda temp_lo
   288 30E7 18			        clc
   289 30E8 65 80		        adc plotX_lo
   290 30EA 85 83		        sta temp_lo
   291
   292 30EC A5 84		        lda temp_hi
   293 30EE 69 00		        adc #0
   294 30F0 85 84		        sta temp_hi
   295 				        ; temp now contains total byte offset from SAVMSC
   296
   297 				        ; Step 4: Add SAVMSC Base Address
   298 30F2 A5 83		        lda temp_lo
   299 30F4 18			        clc
   300 30F5 65 58		        adc SAVMSC
   301 30F7 85 85		        sta scrptr_lo
   302
   303 30F9 A5 84		        lda temp_hi
   304 30FB 65 59		        adc SAVMSC+1
   305 30FD 85 86		        sta scrptr_hi
   306
   307 				        ; Step 5: find which bit to turn on
   308 				        ; algo:  bit position = 7 - (plotX mod 8)
   309 				        ; Step 5: find which bit to turn on
   310 30FF A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   311 3101 A6 89		        ldx bitpos          ; X = number of times to shift right
   312 3103 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   313 3105			shift_loop:
   314 3105 4A			        lsr                 ; shift A right one position
   315 3106 CA			        dex                 ; X = X - 1
   316 3107 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   317 3109			done_shift:
   318 				                            ; A now contains our bit mask
   319
   320 				        ; Step 6: turn on our bit!!
   321 3109 85 8A		        sta bitmask             ; save mask
   322 310B A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   323 310D B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   324 310F 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   325 3111 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   326
   327 3113 60			        rts
   328 				        .endp
