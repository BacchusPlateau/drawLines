    43 				; =====================================================================
    44 				; CIO (Central I/O) constants
    45 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    46 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    47 				; of memory containing command, device, buffer address, and aux bytes.
    48 				; We use IOCB6 (base address $0360) for graphics.
    49 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    50 				; =====================================================================
    51 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    52 = 0342			ICCOM   = $0342     ; IOCB6 command register
    53 				                    ;   $03 = OPEN   (open a device)
    54 				                    ;   $0C = CLOSE  (close a device)
    55 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    56 				                    ;   for OPEN: points to device name string "S:"
    57 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    58 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    59 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    60 				                    ;   for OPEN: $0C = read/write access mode
    61 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    62 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    63
    64 				; =====================================================================
    65 				; Screen RAM pointer
    66 				; After CIO opens GR.8, the OS stores the address of screen RAM
    67 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    68 				; On our 800XL PAL system screen RAM ends up at $B060.
    69 				; =====================================================================
    70 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    71 				                    ; $59 automatically contains the high byte
    72
    73 				; =====================================================================
    74 				; Attract mode constants
    75 				; The Atari OS has an attract mode that kicks in after inactivity
    76 				; to prevent screen burn-in. It does this by desaturating all colors
    77 				; making everything appear as shades of grey/blue.
    78 				; We must continuously reset these in our main loop to keep colors!
    79 				; =====================================================================
    80 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    81 				                    ; when it reaches a threshold attract mode activates
    82 				                    ; we keep writing 0 to prevent it from activating
    83 = 004E			ATRMSK  = $4E       ; attract mode color mask
    84 				                    ; OS ANDs all colors with this value
    85 				                    ; $FE strips hue leaving only luminance (grey/blue)
    86 				                    ; $FF = full color (no masking) — what we want
     2 				        icl 'routines.asm'
