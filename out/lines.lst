    29 				; =====================================================================
    30 				; CIO (Central I/O) constants
    31 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    32 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    33 				; of memory containing command, device, buffer address, and aux bytes.
    34 				; We use IOCB6 (base address $0360) for graphics.
    35 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    36 				; =====================================================================
    37 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    38 = 0342			ICCOM   = $0342     ; IOCB6 command register
    39 				                    ;   $03 = OPEN   (open a device)
    40 				                    ;   $0C = CLOSE  (close a device)
    41 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    42 				                    ;   for OPEN: points to device name string "S:"
    43 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    44 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    45 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    46 				                    ;   for OPEN: $0C = read/write access mode
    47 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    48 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    49
    50 				; =====================================================================
    51 				; Screen RAM pointer
    52 				; After CIO opens GR.8, the OS stores the address of screen RAM
    53 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    54 				; On our 800XL PAL system screen RAM ends up at $B060.
    55 				; =====================================================================
    56 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    57 				                    ; $59 automatically contains the high byte
    58
    59 				; =====================================================================
    60 				; Attract mode constants
    61 				; The Atari OS has an attract mode that kicks in after inactivity
    62 				; to prevent screen burn-in. It does this by desaturating all colors
    63 				; making everything appear as shades of grey/blue.
    64 				; We must continuously reset these in our main loop to keep colors!
    65 				; =====================================================================
    66 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    67 				                    ; when it reaches a threshold attract mode activates
    68 				                    ; we keep writing 0 to prevent it from activating
    69 = 004E			ATRMSK  = $4E       ; attract mode color mask
    70 				                    ; OS ANDs all colors with this value
    71 				                    ; $FE strips hue leaving only luminance (grey/blue)
    72 				                    ; $FF = full color (no masking) — what we want
     2 				        icl 'routines.asm'
Source: routines.asm
     1 				; routines.asm
     2 				        org $3000               ; routines live at $3000
     3
